<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue header banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="#1E3A8A"
            android:paddingTop="40dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- Profile photo picker -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/imgProfilePic"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="#2563EB"
                    android:padding="8dp"/>

                <!-- Camera icon overlay -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:src="@android:drawable/ic_menu_camera"
                    android:background="#FFFFFF"
                    android:padding="4dp"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to add photo"
                android:textColor="#93C5FD"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Find your next internship"
                android:textColor="#93C5FD"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Form card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Section: Personal Info -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL INFO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <!-- Full Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/etStudentName"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Full Name"
                        android:background="@null"
                        android:paddingStart="10dp"
                        android:inputType="textPersonName"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Age + Course row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F8FAFC"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="6dp">
                        <EditText
                            android:id="@+id/etStudentAge"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Age"
                            android:background="@null"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="2"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F8FAFC"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">
                        <EditText
                            android:id="@+id/etStudentCourse"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="Course / Degree"
                            android:background="@null"
                            android:inputType="text"
                            android:textSize="14sp"
                            android:singleLine="true"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Phone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="20dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/stat_notify_missed_call"
                        android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/etStudentPhone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Phone Number"
                        android:background="@null"
                        android:paddingStart="10dp"
                        android:inputType="phone"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Section: Account -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACCOUNT"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="10dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_dialog_email"
                        android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/etStudentEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Email Address"
                        android:background="@null"
                        android:paddingStart="10dp"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F8FAFC"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/etStudentPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Password"
                        android:background="@null"
                        android:paddingStart="10dp"
                        android:inputType="textPassword"
                        android:textSize="14sp"
                        android:singleLine="true"/>
                </LinearLayout>

                <!-- Section: Interests -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INTERESTS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#64748B"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose exactly 5 tags that match your skills"
                    android:textSize="12sp"
                    android:textColor="#94A3B8"
                    android:layout_marginBottom="12dp"/>

                <!-- Tag counter -->
                <TextView
                    android:id="@+id/tvTagCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 5 selected"
                    android:textSize="12sp"
                    android:textColor="#2563EB"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <!-- Tag chips — populated dynamically -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/tagFlexbox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start"
                    android:layout_marginBottom="24dp"/>

                <!-- Register button -->
                <Button
                    android:id="@+id/btnStudentRegister"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Create Account"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#1E3A8A"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvGoToLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? Log in"
                    android:gravity="center"
                    android:textColor="#2563EB"
                    android:textSize="13sp"
                    android:paddingBottom="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>