<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_alt">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/editStuPostTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/surface_card"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnEditBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_secondary"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Post"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/editStuPostTopBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_accent"
                app:boxBackgroundColor="@color/surface_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEditTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Internship Title:" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_accent"
                app:boxBackgroundColor="@color/surface_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEditDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Internship Description:"
                    android:gravity="top|start"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tags (Max 5):"
                android:layout_marginTop="12dp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spEditTagDropdown"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:spinnerMode="dropdown"
                android:layout_marginTop="4dp"
                android:background="@color/surface_card"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected Tags:"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"/>

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/editTagChipsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:flexWrap="wrap"
                app:alignItems="flex_start"
                app:justifyContent="flex_start"/>

            <TextView
                android:id="@+id/tvEditSelectedTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No tags selected"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_accent"
                app:boxBackgroundColor="@color/surface_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEditStipend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Stipend:"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/primary_accent"
                app:boxBackgroundColor="@color/surface_card">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEditTimePeriod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Time Period:" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnUpdateStuPost"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Update Internship"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/primary_accent"
                android:textColor="@color/white"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
