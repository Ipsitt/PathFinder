<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_alt">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tag Management"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_bg"
            android:layout_marginBottom="20dp"/>

        <!-- Existing Tags dropdown card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="3dp"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tags:"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerTags"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Create / Edit Tag card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="3dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Label row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="Label:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <EditText
                        android:id="@+id/etTagLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Enter tag name"
                        android:inputType="text"
                        android:background="@android:drawable/edit_text"
                        android:padding="8dp"/>
                </LinearLayout>

                <!-- Color label + swatch + hex -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="Color:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <!-- Live color swatch -->
                    <View
                        android:id="@+id/colorPreview"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/rounded_rect"/>

                    <!-- Editable hex field -->
                    <EditText
                        android:id="@+id/etColorHex"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="@color/status_error"
                        android:inputType="text"
                        android:maxLength="7"
                        android:fontFamily="monospace"
                        android:textSize="14sp"
                        android:background="@android:drawable/edit_text"
                        android:padding="8dp"/>
                </LinearLayout>

                <!-- ── Discord-style color picker ── -->
                <!-- Big SB square + thin hue bar are both inside ColorPickerView -->
                <com.example.pathfinder.ColorPickerView
                    android:id="@+id/colorPicker"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Save -->
                <Button
                    android:id="@+id/btnSaveTag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Tag"
                    android:backgroundTint="@color/primary_bg"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp"/>

                <!-- Delete selected -->
                <Button
                    android:id="@+id/btnDeleteTag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Delete Selected Tag"
                    android:backgroundTint="@color/status_error"
                    android:textColor="@color/white"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
