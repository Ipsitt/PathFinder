<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="#1E3A8A"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Profile photo -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/org_photo_bg"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:id="@+id/dialogStudentPhoto"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="centerCrop"/>
            </FrameLayout>

            <TextView
                android:id="@+id/dialogStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/dialogStudentEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#93C5FD"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Info section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/dialogStudentAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#334155"
                android:paddingBottom="8dp"/>

            <TextView
                android:id="@+id/dialogStudentCourse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#334155"
                android:paddingBottom="8dp"/>

            <TextView
                android:id="@+id/dialogStudentPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#334155"
                android:paddingBottom="14dp"/>

            <!-- Tags label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Interests"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#64748B"
                android:paddingBottom="8dp"/>

            <!-- Tag chips - populated programmatically -->
            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/dialogStudentTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:flexWrap="wrap"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/dialogBtnClose"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Close"
                android:backgroundTint="#1E3A8A"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>